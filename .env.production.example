# Oracle production environment.
COMPOSE_PROJECT_NAME=new-api-deploy
NEW_API_IMAGE=calciumion/new-api:latest
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2.8-alpine
NGINX_IMAGE=nginx:1.27-alpine

HTTP_PORT=80
HTTPS_PORT=443
MYSQL_PORT=3307
TZ=Asia/Shanghai

APP_CONTAINER_NAME=new-api
CADDY_CONTAINER_NAME=new-api-nginx
HTML_FILTER_CONTAINER_NAME=new-api-html-filter
MYSQL_CONTAINER_NAME=new-api-mysql
REDIS_CONTAINER_NAME=new-api-redis

# Keep production data paths compatible with the existing Oracle install.
NEW_API_DATA_DIR=./data/new-api
MYSQL_DATA_DIR=./data/mysql
REDIS_DATA_DIR=./data/redis

SESSION_SECRET=change-me-to-a-long-random-string
CRYPTO_SECRET=change-me-to-another-long-random-string

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=new_api
MYSQL_USER=new_api
MYSQL_PASSWORD=change-me-db-password

REDIS_PASSWORD=change-me-redis-password
