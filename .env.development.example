# Local development environment.
COMPOSE_PROJECT_NAME=new-api-dev
NEW_API_IMAGE=calciumion/new-api:latest
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2.8-alpine
NGINX_IMAGE=nginx:1.27-alpine

HTTP_PORT=3001
HTTPS_PORT=3443
MYSQL_PORT=3307
TZ=Asia/Shanghai

APP_CONTAINER_NAME=new-api-dev
CADDY_CONTAINER_NAME=new-api-dev-caddy
HTML_FILTER_CONTAINER_NAME=new-api-dev-html-filter
MYSQL_CONTAINER_NAME=new-api-dev-mysql
REDIS_CONTAINER_NAME=new-api-dev-redis

NEW_API_DATA_DIR=./data/development/new-api
MYSQL_DATA_DIR=./data/development/mysql
REDIS_DATA_DIR=./data/development/redis

SESSION_SECRET=change-me-to-a-long-random-string
CRYPTO_SECRET=change-me-to-another-long-random-string

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=new_api
MYSQL_USER=new_api
MYSQL_PASSWORD=change-me-db-password

REDIS_PASSWORD=change-me-redis-password
