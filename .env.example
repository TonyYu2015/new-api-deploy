# New API application
NEW_API_IMAGE=calciumion/new-api:latest
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2.8-alpine
HTTP_PORT=3001
HTTPS_PORT=3443
TZ=Asia/Shanghai

# Replace these before production use.
SESSION_SECRET=change-me-to-a-long-random-string
CRYPTO_SECRET=change-me-to-another-long-random-string

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=new_api
MYSQL_USER=new_api
MYSQL_PASSWORD=change-me-db-password

# Redis
REDIS_PASSWORD=change-me-redis-password
