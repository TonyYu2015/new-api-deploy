# New API application
NEW_API_IMAGE=calciumion/new-api:latest
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:1.27-alpine
NEW_API_PORT=3001
TZ=Asia/Shanghai

# Replace these before production use.
SESSION_SECRET=change-me-to-a-long-random-string
CRYPTO_SECRET=change-me-to-another-long-random-string

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=new_api
MYSQL_USER=new_api
MYSQL_PASSWORD=change-me-db-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# Stripe one-time top-up. Leave empty to disable checkout creation.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3001/stripe/success
STRIPE_CANCEL_URL=http://localhost:3001/stripe/cancel

# Quota credited per paid USD. Adjust this to match your pricing model.
TOPUP_QUOTA_PER_USD=500000
TOPUP_MIN_USD=5
TOPUP_MAX_USD=500
TOPUP_ALLOWED_AMOUNTS=5,10,20,50,100
